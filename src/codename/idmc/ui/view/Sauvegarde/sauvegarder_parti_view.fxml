<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="200.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="codename.idmc.ui.view.sauvegarder_parti.SauvegarderPartiController">

    <top>
        <Label text="Sauvegarder la partie" style="-fx-font-size: 16px; -fx-font-weight: bold;"
               BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets top="20.0" bottom="10.0"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <Label text="Nom de la partie :"/>
                <TextField fx:id="nomPartieField" promptText="Entrez un nom de partie"
                           prefWidth="300.0"/>
                <Label fx:id="messageErreur" text="" style="-fx-text-fill: red;"/>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button text="Annuler" onAction="#annuler"/>
                <Button text="Sauvegarder" onAction="#sauvegarder"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
            </children>
            <BorderPane.margin>
                <Insets bottom="20.0"/>
            </BorderPane.margin>
        </HBox>
    </bottom>

</BorderPane>
