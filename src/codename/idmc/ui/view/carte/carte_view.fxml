<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>

<StackPane fx:id="rootCard"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="codename.idmc.ui.view.card.CarteViewController"
           prefWidth="140.0"
           prefHeight="80.0"
           style="-fx-background-color: white; -fx-border-color: black; -fx-border-width: 1; -fx-background-radius: 8; -fx-border-radius: 8;">
    
    <children>
        <Label fx:id="labelMot"
               text="Mot"
               wrapText="true"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    </children>
</StackPane>