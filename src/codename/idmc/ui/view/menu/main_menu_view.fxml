<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="codename.idmc.ui.view.menu.MainMenuController"
            prefHeight="500.0"
            prefWidth="800.0"
            style="-fx-background-color: #e0e0e0;">

    <top>
        <BorderPane>
            <center>
                <Label text="Code Name IDMC"
                       prefHeight="80.0"
                       prefWidth="400.0"
                       style="-fx-font-weight: bold; -fx-alignment: center;">
                    <font>
                        <Font size="34.0" />
                    </font>
                </Label>
            </center>
        </BorderPane>
    </top>

    <center>
        <VBox alignment="CENTER_LEFT"
              spacing="15.0"
              BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="joinGameButton"
                        mnemonicParsing="false"
                        onAction="#rejoindrePartie"
                        prefWidth="220.0"
                        text="Rejoindre une partie" />

                <Button fx:id="createGameButton"
                        mnemonicParsing="false"
                        onAction="#creerPartie"
                        prefWidth="220.0"
                        text="Créer une partie" />

                <Button fx:id="loadGameButton"
                        mnemonicParsing="false"
                        onAction="#chargerPartie"
                        prefWidth="220.0"
                        text="Charger une partie" />

                <Button fx:id="addNewButton"
                        mnemonicParsing="false"
                        onAction="#ajouterContenu"
                        prefWidth="220.0"
                        text="Ajouter du contenu" />

                <Label fx:id="statusLabel"
                       style="-fx-text-fill: red; -fx-font-size: 13px;" />
            </children>

            <BorderPane.margin>
                <Insets left="40.0" />
            </BorderPane.margin>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="BOTTOM_RIGHT"
              prefHeight="90.0"
              spacing="10.0"
              BorderPane.alignment="CENTER">
            <children>
                <ImageView fx:id="themeIcon"
                           fitHeight="100.0"
                           fitWidth="100.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@/codename/assets/icons/card/Logo_Université_de_Lorraine.png" />
                    </image>
                    <HBox.margin>
                        <Insets bottom="10.0" />
                    </HBox.margin>
                </ImageView>

                <ImageView fx:id="profileIcon"
                           fitHeight="100.0"
                           fitWidth="100.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@/codename/assets/icons/card/idmc-licence-master-informatique-370x320.png" />
                    </image>
                    <HBox.margin>
                        <Insets bottom="10.0" right="10.0" />
                    </HBox.margin>
                </ImageView>
            </children>
        </HBox>
    </bottom>
</BorderPane>